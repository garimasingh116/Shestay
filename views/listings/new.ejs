<% layout("/layouts/boilerplate") %>
<body class="bg-light">

  <div class="container my-5">
    <h2 class="mb-4 text-center text-primary">Create a New SheStay Listing</h2>

    <form method="POST" action="/listings" class="p-4 rounded shadow bg-white"  enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input name="listing[title]" type="text" class="form-control" placeholder="Enter the title" required />
        <div class="valid-feedback">title looks good</div>
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" placeholder="Enter the description" rows="3" required></textarea>
      </div>


             <div class="mb-3">
        <label class="form-label">Image URL</label>
        <input name="listing[image]" type="file" class="form-control" placeholder="Enter image URL"  required/>
      </div>

      <div class="mb-3">
        <label class="form-label">Price (₹)</label>
        <input  name="listing[price]" class="form-control" placeholder="Enter price" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Location</label>
        <input name="listing[location]" type="text" class="form-control" placeholder="Enter location" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Country</label>
        <input name="listing[country]" type="text" class="form-control" placeholder="Enter country" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Women Only?</label>
        <select name="listing[isWomenOnly]" class="form-select">
          <option value="true">Yes</option>
          <option value="false">No</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Host Gender</label>
        <select name="listing[hostGender]" class="form-select">
          <option value="female">Female</option>
          <option value="male">Male</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Has Secure Lock?</label>
        <select name="listing[hasSecureLock]" class="form-select">
          <option value="true">Yes</option>
          <option value="false">No</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Emergency Support?</label>
        <select name="listing[emergencySupport]" class="form-select">
          <option value="true">Yes</option>
          <option value="false">No</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Safety Rating (out of 5)</label>
        <input type="number" step="0.1" min="0" max="5" name="listing[safetyRating]" class="form-control" placeholder="Rate from 0 to 5" />
      </div>

      <div class="text-center">
        <button type="submit" class="btn btn-primary">Create Listing</button>
      </div>
    </form>
  </div>


</body>

