<% layout("/layouts/boilerplate") %>
<body class="bg-light">

  <div class="container my-5">
    <h2 class="mb-4 text-center text-primary">Create a New SheStay Listing</h2>

    <form method="POST" action="/listings" class="p-4 rounded shadow bg-white"  enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input name="listing[title]" type="text" class="form-control" placeholder="Enter the title" required />
        <div class="valid-feedback">title looks good</div>
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" placeholder="Enter the description" rows="3" required></textarea>
      </div>


             <div class="mb-3">
        <label class="form-label">Image URL</label>
        <input name="listing[image]" type="file" class="form-control" placeholder="Enter image URL"  required/>
      </div>

      <div class="mb-3">
        <label class="form-label">Price (₹)</label>
        <input  name="listing[price]" class="form-control" placeholder="Enter price" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Location</label>
        <input name="listing[location]" type="text" class="form-control" placeholder="Enter location" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Country</label>
        <input name="listing[country]" type="text" class="form-control" placeholder="Enter country" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Women Only?</label>
        <select name="listing[isWomenOnly]" class="form-select">
          <option value="true">Yes</option>
          <option value="false">No</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Host Gender</label>
        <select name="listing[hostGender]" class="form-select">
          <option value="female">Female</option>
          <option value="male">Male</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Has Secure Lock?</label>
        <select name="listing[hasSecureLock]" class="form-select">
          <option value="true">Yes</option>
          <option value="false">No</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Emergency Support?</label>
        <select name="listing[emergencySupport]" class="form-select">
          <option value="true">Yes</option>
          <option value="false">No</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Safety Rating (out of 5)</label>
        <input type="number" step="0.1" min="0" max="5" name="listing[safetyRating]" class="form-control" placeholder="Rate from 0 to 5" />
      </div>
      <hr class="my-4">

<h4 class="text-primary mb-3">Women Safety Features</h4>

<div class="row">

  <div class="col-md-6 mb-3">
    <label class="form-label">Female Staff Available?</label>

    <select name="listing[femaleStaffAvailable]" class="form-select">
      <option value="true">Yes</option>
      <option value="false">No</option>
    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label class="form-label">24/7 Security?</label>

    <select name="listing[security24x7]" class="form-select">
      <option value="true">Yes</option>
      <option value="false">No</option>
    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label class="form-label">CCTV Available?</label>

    <select name="listing[hasCCTV]" class="form-select">
      <option value="true">Yes</option>
      <option value="false">No</option>
    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label class="form-label">Gated Property?</label>

    <select name="listing[gatedProperty]" class="form-select">
      <option value="true">Yes</option>
      <option value="false">No</option>
    </select>
  </div>

</div>

<hr class="my-4">

<h4 class="text-primary mb-3">Night Safety</h4>

<div class="row">

  <div class="col-md-6 mb-3">
    <label class="form-label">Late Night Check-in?</label>

    <select name="listing[lateNightCheckin]" class="form-select">
      <option value="true">Yes</option>
      <option value="false">No</option>
    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label class="form-label">Well Lit Area?</label>

    <select name="listing[wellLitArea]" class="form-select">
      <option value="true">Yes</option>
      <option value="false">No</option>
    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label class="form-label">Night Cab Availability?</label>

    <select name="listing[cabAvailabilityNight]" class="form-select">
      <option value="true">Yes</option>
      <option value="false">No</option>
    </select>
  </div>

</div>

<hr class="my-4">

<h4 class="text-primary mb-3">Area Safety</h4>

<div class="row">

  <div class="col-md-6 mb-3">
    <label class="form-label">Nearby Police Station?</label>

    <select name="listing[nearbyPoliceStation]" class="form-select">
      <option value="true">Yes</option>
      <option value="false">No</option>
    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label class="form-label">Public Transport Nearby?</label>

    <select name="listing[publicTransportNearby]" class="form-select">
      <option value="true">Yes</option>
      <option value="false">No</option>
    </select>
  </div>

</div>

<hr class="my-4">

<h4 class="text-primary mb-3">AI Safety Tags</h4>

<div class="mb-3">
  <label class="form-label">Safety Tags</label>

  <input
    type="text"
    name="listing[safetyTags]"
    class="form-control"
    placeholder="solo-women-friendly, late-night-safe, near-airport"
  />
</div>

      <div class="text-center">
        <button type="submit" class="btn btn-primary">Create Listing</button>
      </div>
    </form>
  </div>


</body> this was initial form