<% layout("/layouts/boilerplate") %>

<body class="bg-light">

  <div class="container my-5">

    <h3 class="mb-4 text-center text-primary">
      Listing Details
    </h3>

    <div class="card shadow">

      <div class="card-body">

        <ul class="list-group list-group-flush">

          <li class="list-group-item">
            <strong>Title:</strong>
            <%= listing.title %>
          </li>

          <% if (listing.owner) { %>
            <li class="list-group-item">
              <strong>Hosted By:</strong>
              <i><%= listing.owner.username %></i>
            </li>
          <% } %>

          <li class="list-group-item">
            <strong>Description:</strong>
            <%= listing.description %>
          </li>

          <li class="list-group-item">

            <strong>Image:</strong><br><br>

            <% if (listing.image && listing.image.url) { %>

              <img
                src="<%= listing.image.url %>"
                class="img-fluid rounded shadow"
                style="max-height: 400px;"
              >

            <% } else { %>

              <p>No image uploaded.</p>

            <% } %>

          </li>

          <li class="list-group-item">
            <strong>Price:</strong>
            ₹<%= listing.price %>
          </li>

          <li class="list-group-item">
            <strong>Location:</strong>
            <%= listing.location %>,
            <%= listing.country %>
          </li>

          <li class="list-group-item">
            <strong>Women Only:</strong>
            <%= listing.isWomenOnly ? "Yes" : "No" %>
          </li>

          <li class="list-group-item">
            <strong>Host Gender:</strong>
            <%= listing.hostGender %>
          </li>

          <li class="list-group-item">
            <strong>Secure Lock:</strong>
            <%= listing.hasSecureLock ? "Yes" : "No" %>
          </li>

          <li class="list-group-item">
            <strong>Emergency Support:</strong>
            <%= listing.emergencySupport ? "Yes" : "No" %>
          </li>

          <li class="list-group-item">
            <strong>Safety Rating:</strong>

            <div class="progress mt-2">

              <div
                class="progress-bar bg-success"
                role="progressbar"
                style="width: <%= listing.safetyRating * 20 %>%">

                <%= listing.safetyRating %>/5

              </div>

            </div>
          </li>

          <!-- NEW WOMEN SAFETY FEATURES -->

          <li class="list-group-item">
            <strong>24/7 Security:</strong>
            <%= listing.security24x7 ? "Yes" : "No" %>
          </li>

          <li class="list-group-item">
            <strong>CCTV Available:</strong>
            <%= listing.hasCCTV ? "Yes" : "No" %>
          </li>

          <li class="list-group-item">
            <strong>Female Staff Available:</strong>
            <%= listing.femaleStaffAvailable ? "Yes" : "No" %>
          </li>

          <li class="list-group-item">
            <strong>Late Night Check-in:</strong>
            <%= listing.lateNightCheckin ? "Yes" : "No" %>
          </li>

          <li class="list-group-item">
            <strong>Well Lit Area:</strong>
            <%= listing.wellLitArea ? "Yes" : "No" %>
          </li>

          <li class="list-group-item">
            <strong>Night Cab Availability:</strong>
            <%= listing.cabAvailabilityNight ? "Yes" : "No" %>
          </li>

          <li class="list-group-item">
            <strong>Nearby Police Station:</strong>
            <%= listing.nearbyPoliceStation ? "Yes" : "No" %>
          </li>

          <li class="list-group-item">
            <strong>Public Transport Nearby:</strong>
            <%= listing.publicTransportNearby ? "Yes" : "No" %>
          </li>

        </ul>

        <!-- AI SAFETY INSIGHT -->

        <div class="alert alert-info mt-4 shadow-sm">

          <h5 class="text-primary">
            AI Safety Insight
          </h5>

          <% if (
            listing.security24x7 &&
            listing.hasCCTV &&
            listing.lateNightCheckin
          ) { %>

            <p>
              This property appears suitable for solo women travelers,
              especially for late-night arrivals, because it offers
              24/7 security, CCTV monitoring, and late-night check-in.
            </p>

          <% } else { %>

            <p>
              Travelers should carefully review safety features
              before booking this property.
            </p>

          <% } %>

        </div>

      </div>
    </div>

    <!-- OWNER BUTTONS -->

    <% if (
      currUser &&
      currUser._id.toString() === listing.owner._id.toString()
    ) { %>

      <div class="mt-4 d-flex gap-2 justify-content-center">

        <a
          href="/listings/<%= listing._id %>/edit"
          class="btn btn-warning">

          Edit Listing

        </a>

        <form
          method="POST"
          action="/listings/<%= listing._id %>?_method=DELETE"
          onsubmit="return confirm('Delete this listing?');">

          <button class="btn btn-danger">
            Delete Listing
          </button>

        </form>

      </div>

    <% } %>

    <hr>

    <!-- REVIEW FORM -->

    <div class="col-8 offset-2">

      <% if (currUser && currUser._id) { %>

        <h4 class="mb-4 text-primary">
          Leave a Review
        </h4>

        <form action="/listings/<%= listing.id %>/reviews" method="POST">

          <!-- STAR RATING -->

          <fieldset class="starability-slot">

            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1">1 star</label>

            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2">2 stars</label>

            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3">3 stars</label>

            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4">4 stars</label>

            <input type="radio" id="first-rate5" name="review[rating]" value="5" checked />
            <label for="first-rate5">5 stars</label>

          </fieldset>

          <!-- COMMENT -->

          <div class="mb-3">

            <label for="comment" class="form-label">
              Comment
            </label>

            <textarea
              name="review[comment]"
              id="comment"
              class="form-control"
              rows="4"
              required></textarea>

          </div>

          <!-- FELT SAFE -->

          <div class="mb-3">

            <label class="form-label">
              Did you feel safe?
            </label><br>

            <input
              type="radio"
              id="safeYes"
              name="review[feltSafe]"
              value="true"
              checked>

            <label for="safeYes">Yes</label>

            <input
              type="radio"
              id="safeNo"
              name="review[feltSafe]"
              value="false">

            <label for="safeNo">No</label>

          </div>

          <!-- SOLO WOMEN -->

          <div class="mb-3">

            <label class="form-label">
              Safe for Solo Women?
            </label><br>

            <input
              type="radio"
              id="soloYes"
              name="review[safeForSoloWomen]"
              value="true"
              checked>

            <label for="soloYes">Yes</label>

            <input
              type="radio"
              id="soloNo"
              name="review[safeForSoloWomen]"
              value="false">

            <label for="soloNo">No</label>

          </div>

          <!-- LATE NIGHT EXPERIENCE -->

          <div class="mb-3">

            <label class="form-label">
              Late Night Experience
            </label>

            <textarea
              name="review[lateNightExperience]"
              class="form-control"
              rows="3"
              placeholder="Describe your late-night experience"></textarea>

          </div>

          <button class="btn btn-primary">
            Submit Review
          </button>

        </form>

      <% } %>

    </div>

    <hr>

    <!-- ALL REVIEWS -->

    <h4 class="mt-4 mb-3 text-primary">
      All Reviews
    </h4>

    <ul class="list-unstyled">

      <% for (let review of listing.reviews) { %>

        <li class="card mb-3 shadow-sm">

          <div class="card-body">

            <p>
              <strong>By:</strong>
              <%= review.author?.username || "Anonymous" %>
            </p>

            <p>
              <strong>Rating:</strong>
              <%= review.rating %>/5
            </p>

            <p>
              <strong>Comment:</strong>
              <%= review.comment %>
            </p>

            <p>
              <strong>Felt Safe:</strong>

              <span class="<%= review.feltSafe ? 'text-success' : 'text-danger' %>">

                <%= review.feltSafe ? "Yes" : "No" %>

              </span>
            </p>

            <p>
              <strong>Safe for Solo Women:</strong>

              <span class="<%= review.safeForSoloWomen ? 'text-success' : 'text-danger' %>">

                <%= review.safeForSoloWomen ? "Yes" : "No" %>

              </span>
            </p>

            <% if(review.lateNightExperience){ %>

              <p>
                <strong>Late Night Experience:</strong>
                <%= review.lateNightExperience %>
              </p>

            <% } %>

            <form
              method="POST"
              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

              <button class="btn btn-sm btn-danger">
                Delete
              </button>

            </form>

          </div>

        </li>

      <% } %>

    </ul>

  </div>

</body>