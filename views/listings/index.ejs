<% layout("/layouts/boilerplate") %>

<style>
  #filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 1rem;
    padding: 1rem;
    background-color: #f8f9fa;
    border-radius: 0.5rem;
  }

  .filter {
    text-align: center;
    color: #6f42c1;
    font-size: 0.9rem;
    transition: opacity 0.2s;
    opacity: 0.7;
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }

  .filter i {
    font-size: 1.2rem;
  }

  .card-img-top {
    height: 250px;
    object-fit: cover;
  }

  #tax-info {
    font-size: 0.85rem;
    color: #6c757d;
  }
</style>

<%= success %>

<body>
  <!-- Filter bar -->
  <div id="filters" class="shadow-sm">
    <div class="filter">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-mountain-sun"></i></div>
      <p>Iconic Cities</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing Pools</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-chess-rook"></i></div>
      <p>Castle</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-tents"></i></div>
      <p>Camping</p>
    </div>

    <div class="form-check form-switch d-flex align-items-center ms-3">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label ms-2 text-muted" for="switchCheckDefault">Show tax</label>
    </div>
  </div>

  <!-- Listings -->
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-3 justify-content-center">
    <% for(let listing of allListing){ %>
      <div class="col">
        <a href="/listings/<%=listing._id %>" class="text-decoration-none text-dark">
          <div class="card h-100 shadow-sm">
            <img class="card-img-top" src="<%= listing.image.url %>" alt="listing_image">
            <div class="card-body">
              <p class="card-text mb-1 fw-semibold">
                <%= listing.title %> – ₹<%= listing.price %>
                <span id="tax-info"> &nbsp;+18% GST</span>
              </p>
              <% if (listing.femaleSafe === true || listing.femaleSafe === "true") { %>
                <span class="badge bg-success">Female-safe</span>
              <% } %>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>
</body>

<script>
  const taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    const taxInfoElements = document.querySelectorAll("#tax-info");
    for (let el of taxInfoElements) {
      el.style.display = (el.style.display === "none" || el.style.display === "") ? "inline" : "none";
    }
  });
</script>
